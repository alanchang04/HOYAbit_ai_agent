# === LLM backend 切換 ===
# bedrock：競賽正式規定唯一合法後端，正式執行/繳交前必須設為 bedrock
# gemini：僅供尚未取得 Bedrock 存取權限時，開發階段暫代測試 prompt 用
LLM_BACKEND=bedrock

# === AWS Bedrock（必要，硬性限制：LLM 推理僅能使用 Bedrock 上的模型）===
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# 需另外設定 AWS 認證，建議用 AWS CLI `aws configure` 或環境變數
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# === Gemini（開發階段暫代用，正式比賽不得使用）===
# 免費層每日額度是「每專案每模型」各自計算，建議申請一組獨立的 GCP 專案/API key
# 專門給這個專案用，避免跟你其他 Gemini 應用搶額度。
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.5-flash

# === 選用：各 collector 的補充 API key（缺少時會退回免 key 端點或標記 skipped）===
CRYPTOPANIC_API_KEY=
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
FRED_API_KEY=

# === 執行時間控制（秒）===
HARD_DEADLINE_SECONDS=900
DEGRADED_MODE_TRIGGER_SECONDS=720
COLLECTOR_TIMEOUT_SECONDS=75

# === 路徑設定 ===
DATA_DIR=data
OUTPUT_DIR=output
