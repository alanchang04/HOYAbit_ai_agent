# === AWS Bedrock（必要，硬性限制：LLM 推理僅能使用 Bedrock 上的模型）===
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# 需另外設定 AWS 認證，建議用 AWS CLI `aws configure` 或環境變數
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# === 選用：各 collector 的補充 API key（缺少時會退回免 key 端點或標記 skipped）===
CRYPTOPANIC_API_KEY=
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
FRED_API_KEY=

# === 執行時間控制（秒）===
HARD_DEADLINE_SECONDS=900
DEGRADED_MODE_TRIGGER_SECONDS=720
COLLECTOR_TIMEOUT_SECONDS=75

# === 路徑設定 ===
DATA_DIR=data
OUTPUT_DIR=output
